# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — it holds secrets and must never be committed.
# config.py loads it automatically at startup (real environment variables win).

# PostgreSQL connection string for the `worldcup` database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# The engine uses a dedicated, least-privilege `worldcup_app` role (not the
# shared one). To (re)create it locally, as the postgres superuser:
#   CREATE ROLE worldcup_app LOGIN PASSWORD 'choose-a-strong-one';
#   GRANT CONNECT, TEMP ON DATABASE worldcup TO worldcup_app;
#   ALTER DATABASE worldcup OWNER TO worldcup_app;   -- so it owns its own schema
WORLDCUP_DATABASE_URL=postgresql://worldcup_app:CHANGE_ME@localhost:5432/worldcup

# Live results feed: football-data.org v4 (competition WC). Free token from
# https://www.football-data.org/client/register . Required for `ingest live`/`refresh`.
WCPA_FOOTBALLDATA_TOKEN=CHANGE_ME

# Legacy/fallback: TheSportsDB API key. The free public test key "3" works out of
# the box; sportsdb is no longer the live feed but viz/server.py still uses it for
# best-effort goal timelines.
# SPORTSDB_KEY=3

# --------------------------------------------------------------------------- #
# Cloud automation (GitHub Actions) — set these as repo Secrets, NOT in .env.
# GitHub → repo → Settings → Secrets and variables → Actions → New repository secret
# --------------------------------------------------------------------------- #
# WORLDCUP_DATABASE_URL    managed Postgres (e.g. a free Neon project) connection string
#                          postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# WCPA_FOOTBALLDATA_